---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from '../../lib/sanity';

export async function getStaticPaths() {
  const collections = [
    { slug: 'monochrome', name: 'Monochrome' },
    { slug: 'azure-deep', name: 'Azure Deep' },
    { slug: 'velvet-night', name: 'Velvet Night' },
    { slug: 'terra-cotta', name: 'Terra Cotta' },
  ];

  return collections.map((collection) => {
    return {
      params: { slug: collection.slug },
      props: { name: collection.name }
    };
  });
}

const { slug } = Astro.params;
const { name } = Astro.props;

let products: any[] = [];
try {
  products = await sanityClient.fetch(`*[_type == "product" && collection == $slug]{
    _id,
    title,
    "description": pt::text(description),
    "imageUrl": featuredImage.asset->url
  }`, { slug });
} catch (error) {
  console.error("Error fetching products from Sanity:", error);
}

// Fallback mock data if CMS is empty or errors
if (!products || products.length === 0) {
  const allMockProducts = [
    {
      _id: "mock-1",
      title: "Queen of Orisun",
      description: "Original Canvas",
      imageUrl: "https://images.unsplash.com/photo-1579762715118-a6f1d4b934f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "monochrome"
    },
    {
      _id: "mock-2",
      title: "Night Bloom",
      description: "Art Print",
      imageUrl: "https://images.unsplash.com/photo-1507608158173-1dcec673a2e5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "azure-deep"
    },
    {
      _id: "mock-3",
      title: "Golden Hour",
      description: "Mixed Media",
      imageUrl: "https://images.unsplash.com/photo-1550684376-efcbd6e3f031?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "velvet-night"
    },
    {
      _id: "mock-4",
      title: "Azure Deep",
      description: "Original Canvas",
      imageUrl: "https://images.unsplash.com/photo-1541961017774-22349e4a1262?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "terra-cotta"
    }
  ];
  products = allMockProducts.filter(p => p.collection === slug);
}
---

<Layout>
  <!-- Header -->
  <header class="flex items-center justify-between px-6 py-6 border-b border-[#EBE6DC] bg-[#FCFBF8]">
    <div class="flex items-center gap-4">
      <a href="/" class="text-xl font-bold tracking-tight text-[#2D2A26]">WallsbyYemisi</a>
    </div>

    <div class="flex items-center gap-4">
      <button class="w-10 h-10 rounded-full bg-[#F5F2EA] flex items-center justify-center text-[#333333] hover:bg-[#EAE5D9] transition" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <button class="w-10 h-10 rounded-full bg-[#2D2A26] flex items-center justify-center text-[#F5F2EA] hover:bg-black transition relative" aria-label="Cart" onclick="window.location.href='/cart'">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
          <path d="M3 6h18"></path>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="cart-badge absolute -top-1 -right-1 bg-[#D4AF37] text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center hidden">0</span>
      </button>
    </div>
  </header>

  <main class="container mx-auto px-4 py-8 max-w-lg md:max-w-4xl min-h-[60vh]">
    <div class="mb-8">
      <a href="/" class="text-[#D4AF37] hover:underline flex items-center gap-2 mb-4 text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back to Home
      </a>
      <h1 class="text-4xl font-bold text-[#2D2A26] capitalize" transition:name={`collection-title-${slug}`}>{name}</h1>
    </div>

    {products.length === 0 ? (
      <p class="text-center text-gray-500 text-xl py-12">No products found in this collection.</p>
    ) : (
      <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:gap-6">
        {products.map((product) => (
          <a href={`/product/${product._id}`} class="block transition hover:-translate-y-1">
            <div class="bg-[#FDFBF7] rounded-[24px] p-2 flex flex-col shadow-sm border border-[#F3EFE6] h-full">
              <div class="relative w-full aspect-square rounded-[20px] overflow-hidden mb-3 bg-[#F5F2EA]">
                <img src={product.imageUrl} alt={product.title} class="w-full h-full object-cover mix-blend-multiply" />
                <button class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white flex items-center justify-center shadow-sm text-[#D4AF37] hover:bg-[#FDFBF7] transition">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
                  </svg>
                </button>
              </div>
              <div class="px-2 pb-2 flex flex-col flex-grow">
                <h3 class="font-bold text-[#2D2A26] text-sm md:text-base leading-tight mb-1">{product.title}</h3>
                <p class="text-[#A39E93] text-xs mb-3 flex-grow">{product.description || 'Artwork'}</p>
                <div class="flex justify-between items-center mt-auto">
                  <span class="text-[#C59F58] font-bold text-lg">₦75,000</span>
                  <button
                    class="w-8 h-8 rounded-full bg-[#F5F2EA] flex items-center justify-center text-[#C59F58] hover:bg-[#EAE5D9] transition"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" x2="12" y1="5" y2="19"></line>
                      <line x1="5" x2="19" y1="12" y2="12"></line>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>

  <!-- Footer -->
  <footer class="bg-[#F3EFE6] px-8 py-12 rounded-t-[40px] mt-8">
    <div class="max-w-lg md:max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-[#C59F58] mb-4">WallsbyYemisi</h2>
      <p class="text-[#2D2A26] mb-8 max-w-sm leading-relaxed">Curating contemporary African art for modern spaces.</p>

      <div class="mb-8">
        <h3 class="text-[#D4AF37] text-sm font-bold tracking-widest uppercase mb-4">Contact Us</h3>
        <div class="flex flex-col gap-4">
          <a href="mailto:hello@wallsbyyemisi.com" class="flex items-center gap-3 text-[#2D2A26] hover:text-[#C59F58] transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <span class="text-lg">hello@wallsbyyemisi.com</span>
          </a>
          <a href="tel:+1234567890" class="flex items-center gap-3 text-[#2D2A26] hover:text-[#C59F58] transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span class="text-lg">+1 (234) 567-890</span>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-[#D4AF37] text-sm font-bold tracking-widest uppercase mb-4">Follow Our Journey</h3>
        <div class="flex gap-4">
          <a href="#" class="w-12 h-12 rounded-[16px] bg-[#EAE5D9] flex items-center justify-center text-[#D4AF37] hover:bg-[#D4AF37] hover:text-white transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
            </svg>
          </a>
          <a href="#" class="w-12 h-12 rounded-[16px] bg-[#EAE5D9] flex items-center justify-center text-[#D4AF37] hover:bg-[#D4AF37] hover:text-white transition">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </footer>
</Layout>
