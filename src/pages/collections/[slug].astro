---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { sanityClient } from '../../lib/sanity';

export async function getStaticPaths() {
  let collections = [];
  try {
    collections = await sanityClient.fetch(`*[_type == "collection"]{
      "slug": slug.current,
      "name": title
    }`);
  } catch (error) {
    console.error("Error fetching collections for paths:", error);
  }

  if (!collections || collections.length === 0) {
    collections = [
      { slug: 'monochrome', name: 'Monochrome' },
      { slug: 'azure-deep', name: 'Azure Deep' },
      { slug: 'velvet-night', name: 'Velvet Night' },
      { slug: 'terra-cotta', name: 'Terra Cotta' },
    ];
  }

  return collections.map((collection: any) => {
    return {
      params: { slug: collection.slug },
      props: { name: collection.name }
    };
  });
}

const { slug } = Astro.params;
const { name } = Astro.props;

let products: any[] = [];
try {
  products = await sanityClient.fetch(`*[_type == "product" && collection == $slug]{
    _id,
    title,
    "description": pt::text(description),
    "imageUrl": featuredImage.asset->url,
    "price": variants[0].price
  }`, { slug });
} catch (error) {
  console.error("Error fetching products from Sanity:", error);
}

// Fallback mock data if CMS is empty or errors
if (!products || products.length === 0) {
  const allMockProducts = [
    {
      _id: "mock-1",
      title: "Queen of Orisun",
      description: "Original Canvas",
      imageUrl: "https://images.unsplash.com/photo-1579762715118-a6f1d4b934f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "monochrome",
      price: 75000
    },
    {
      _id: "mock-2",
      title: "Night Bloom",
      description: "Art Print",
      imageUrl: "https://images.unsplash.com/photo-1507608158173-1dcec673a2e5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "azure-deep",
      price: 75000
    },
    {
      _id: "mock-3",
      title: "Golden Hour",
      description: "Mixed Media",
      imageUrl: "https://images.unsplash.com/photo-1550684376-efcbd6e3f031?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "velvet-night",
      price: 75000
    },
    {
      _id: "mock-4",
      title: "Azure Deep",
      description: "Original Canvas",
      imageUrl: "https://images.unsplash.com/photo-1541961017774-22349e4a1262?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
      collection: "terra-cotta",
      price: 75000
    }
  ];
  products = allMockProducts.filter(p => p.collection === slug);
}
---

<Layout>
  <!-- Header -->
  <Header />

  <main class="container mx-auto px-4 py-8 max-w-lg md:max-w-4xl min-h-[60vh]">
    <div class="mb-8">
      <a href="/" class="text-[#D4AF37] hover:underline flex items-center gap-2 mb-4 text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Back to Home
      </a>
      <h1 class="text-4xl font-bold text-[#2D2A26] capitalize" transition:name={`collection-title-${slug}`}>{name}</h1>
    </div>

    {products.length === 0 ? (
      <p class="text-center text-gray-500 text-xl py-12">No products found in this collection.</p>
    ) : (
      <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:gap-6">
        {products.map((product) => (
          <a href={`/product/${product._id}`} class="block transition hover:-translate-y-1">
            <div class="bg-[#FDFBF7] rounded-[24px] p-2 flex flex-col shadow-sm border border-[#F3EFE6] h-full">
              <div class="relative w-full aspect-square rounded-[20px] overflow-hidden mb-3 bg-[#F5F2EA]">
                <img src={product.imageUrl} alt={product.title} class="w-full h-full object-cover mix-blend-multiply" />
                <button class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white flex items-center justify-center shadow-sm text-[#D4AF37] hover:bg-[#FDFBF7] transition">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
                  </svg>
                </button>
              </div>
              <div class="px-2 pb-2 flex flex-col flex-grow">
                <h3 class="font-bold text-[#2D2A26] text-sm md:text-base leading-tight mb-1">{product.title}</h3>
                <p class="text-[#A39E93] text-xs mb-3 flex-grow">{product.description || 'Artwork'}</p>
                <div class="flex justify-between items-center mt-auto">
                  <span class="text-[#C59F58] font-bold text-lg">₦{product.price ? product.price.toLocaleString() : '75,000'}</span>
                  <button
                    class="w-8 h-8 rounded-full bg-[#F5F2EA] flex items-center justify-center text-[#C59F58] hover:bg-[#EAE5D9] transition"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" x2="12" y1="5" y2="19"></line>
                      <line x1="5" x2="19" y1="12" y2="12"></line>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>

  <!-- Footer -->
  <Footer />
</Layout>
