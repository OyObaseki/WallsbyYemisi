  </footer>

  <style>
    /* Hide scrollbar for Chrome, Safari and Opera */
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    .hide-scrollbar {
      -ms-overflow-style: none;  /* IE and Edge */
      scrollbar-width: none;  /* Firefox */
    }
  </style>

  <script>
    // Module level variable to clear interval
    let autoSlideInterval;
    let cleanupFunctions = [];

    // Clear interval before swap to avoid memory leaks
    document.addEventListener('astro:before-swap', () => {
      if (autoSlideInterval) clearInterval(autoSlideInterval);
      cleanupFunctions.forEach(fn => fn());
      cleanupFunctions = [];
    });

    document.addEventListener('astro:page-load', () => {
      const track = document.getElementById('hero-carousel-track');
      const dots = document.querySelectorAll('.hero-dot');
      if (!track || dots.length === 0) return;

      let currentIndex = 0;
      const slideCount = dots.length;
      let startX = 0;
      let startY = 0;
      let currentTranslate = 0;
      let prevTranslate = 0;
      let isDragging = false;
      let isScrolling = false;

      function goToSlide(index) {
        if (index < 0) index = slideCount - 1;
        if (index >= slideCount) index = 0;
        currentIndex = index;

        track.style.transition = 'transform 0.5s ease-in-out';
        track.style.transform = `translateX(-${currentIndex * 100}%)`;

        dots.forEach((dot, i) => {
          if (i === currentIndex) {
            dot.className = 'hero-dot w-6 h-2 rounded-full bg-[#D4AF37] transition-all duration-300';
          } else {
            dot.className = 'hero-dot w-2 h-2 rounded-full bg-[#EAE5D9] transition-all duration-300';
          }
        });
      }

      function nextSlide() {
        goToSlide(currentIndex + 1);
      }

      function startAutoSlide() {
        stopAutoSlide();
        autoSlideInterval = setInterval(nextSlide, 5000);
      }

      function stopAutoSlide() {
        if (autoSlideInterval) clearInterval(autoSlideInterval);
      }

      // Initialize
      prevTranslate = currentIndex * -100;

      // Dots click
      dots.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const index = parseInt(target.dataset.index || '0', 10);
          goToSlide(index);
          startAutoSlide();
        });
      });

      // Touch and mouse events for swiping
      function handleDragStart(e) {
        // Only allow left click
        if (e.type === 'mousedown' && e.button !== 0) return;

        if (e.type === 'mousedown' && (e.target.tagName === 'IMG' || e.target.tagName === 'A')) {
          e.preventDefault();
        }

        isDragging = true;
        isScrolling = false;
        startX = e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
        startY = e.type.includes('mouse') ? e.pageY : e.touches[0].clientY;
        stopAutoSlide();

        const transformMatrix = window.getComputedStyle(track).getPropertyValue('transform');
        if (transformMatrix !== 'none') {
          prevTranslate = parseInt(transformMatrix.split(',')[4].trim());
        } else {
          prevTranslate = 0;
        }
        track.style.transition = 'none'; // Disable transition during drag
      }

      function handleDragMove(e) {
        if (!isDragging) return;

        const currentX = e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
        const currentY = e.type.includes('mouse') ? e.pageY : e.touches[0].clientY;

        const diffX = currentX - startX;
        const diffY = currentY - startY;

        // Determine if user is scrolling vertically
        if (e.type.includes('touch') && Math.abs(diffY) > Math.abs(diffX) && !isScrolling) {
          isDragging = false;
          return;
        }

        // Prevent default scrolling only if we are swiping horizontally
        if (e.cancelable && Math.abs(diffX) > Math.abs(diffY)) {
          e.preventDefault();
        }
        isScrolling = true;

        currentTranslate = prevTranslate + diffX;
        track.style.transform = `translateX(${currentTranslate}px)`;
      }

      function handleDragEnd(e) {
        if (!isDragging) return;
        isDragging = false;

        const endX = e.type.includes('mouse') ? e.pageX : (e.changedTouches ? e.changedTouches[0].clientX : startX);
        const diffX = endX - startX;

        // Threshold for swipe
        if (Math.abs(diffX) > 50) {
          if (diffX > 0) {
            goToSlide(currentIndex - 1);
          } else {
            goToSlide(currentIndex + 1);
          }
        } else {
          goToSlide(currentIndex); // Snap back
        }
        startAutoSlide();
      }

      // Touch Events
      // Note: passive is false because we might preventDefault in touchmove
      track.addEventListener('touchstart', handleDragStart, { passive: true });
      track.addEventListener('touchmove', handleDragMove, { passive: false });
      track.addEventListener('touchend', handleDragEnd);

      // Mouse Events
      track.addEventListener('mousedown', handleDragStart);
      window.addEventListener('mousemove', handleDragMove);
      window.addEventListener('mouseup', handleDragEnd);

      // Prevent dragging links from firing navigation when swiping
      let isClickAllowed = true;

      const mousedownClickAllow = () => { isClickAllowed = true; };
      const touchstartClickAllow = () => { isClickAllowed = true; };

      track.addEventListener('mousedown', mousedownClickAllow);
      track.addEventListener('touchstart', touchstartClickAllow, { passive: true });

      const mousemoveClickAllow = (e) => {
        if (isDragging && Math.abs(e.movementX) > 0) {
          isClickAllowed = false;
        }
      };

      const touchmoveClickAllow = (e) => {
        if (isDragging && isScrolling) {
          isClickAllowed = false;
        }
      };

      track.addEventListener('mousemove', mousemoveClickAllow);
      track.addEventListener('touchmove', touchmoveClickAllow, { passive: false });

      const links = track.querySelectorAll('a');
      const clickHandler = (e) => {
        if (!isClickAllowed) {
          e.preventDefault();
        }
      };
      links.forEach(link => {
        link.addEventListener('click', clickHandler);
      });

      // Handle resize
      const handleResize = () => {
        goToSlide(currentIndex);
      };
      window.addEventListener('resize', handleResize);

      // Setup cleanup
      cleanupFunctions.push(() => {
        window.removeEventListener('mousemove', handleDragMove);
        window.removeEventListener('mouseup', handleDragEnd);
        window.removeEventListener('resize', handleResize);
      });

      // Start auto slide initially
      startAutoSlide();

      // New Arrivals Tabs Logic
      const newArrivalsTabs = document.querySelectorAll('.new-arrivals-tab');
      const newArrivalsGrids = document.querySelectorAll('.new-arrivals-grid');

      newArrivalsTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          // Remove active classes from all tabs
          newArrivalsTabs.forEach(t => {
            t.classList.remove('active', 'text-[#D4AF37]', 'border-b-2', 'border-[#D4AF37]');
            t.classList.add('text-[#A39E93]');
          });

          // Add active classes to clicked tab
          tab.classList.remove('text-[#A39E93]');
          tab.classList.add('active', 'text-[#D4AF37]', 'border-b-2', 'border-[#D4AF37]');

          // Hide all grids
          newArrivalsGrids.forEach(grid => {
            grid.classList.add('hidden');
          });

          // Show target grid
          const targetId = tab.getAttribute('data-target');
          if (targetId) {
            const targetGrid = document.getElementById(targetId);
            if (targetGrid) {
              targetGrid.classList.remove('hidden');
            }
          }
        });
      });
    });
  </script>
</Layout>
