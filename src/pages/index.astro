---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from '../lib/sanity';

// Fetch products from Sanity CMS
// Assuming a 'product' schema with title, price, description, and an image.
// We are catching errors so the page can still render even if the CMS is not fully setup yet.
let products: any[] = [];
try {
  products = await sanityClient.fetch(`*[_type == "product"]{
    _id,
    title,
    "price": variants[0].price,
    "description": pt::text(description),
    "imageUrl": featuredImage.asset->url
  }`);
} catch (error) {
  console.error("Error fetching products from Sanity:", error);
}

---

<Layout>
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold mb-8 text-center">Artwork Gallery</h1>

    {products.length === 0 ? (
      <p class="text-center text-gray-500 text-xl">No products found.</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <div class="border rounded-lg overflow-hidden shadow-lg bg-white flex flex-col">
            <img src={product.imageUrl} alt={product.title} class="w-full h-48 object-cover" />
            <div class="p-6 flex flex-col flex-grow">
              <h2 class="text-2xl font-semibold mb-2">{product.title}</h2>
              <p class="text-gray-600 mb-4 flex-grow">{product.description}</p>
              <div class="flex justify-between items-center mt-auto">
                <span class="text-xl font-bold">NGN {product.price}</span>
                <button
                  class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition"
                  data-paystack-btn
                  data-product-id={product._id}
                  data-product-price={product.price * 100}
                  data-product-title={product.title}
                >
                  Buy Now
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </main>

  <script>
    import PaystackPop from '@paystack/inline-js';

    // A script to attach event listeners to all 'Buy Now' buttons
    document.addEventListener("DOMContentLoaded", () => {
      const buyButtons = document.querySelectorAll('[data-paystack-btn]');

      buyButtons.forEach(button => {
        button.addEventListener('click', (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          const productId = btn.getAttribute('data-product-id');
          const productPrice = btn.getAttribute('data-product-price');
          const productTitle = btn.getAttribute('data-product-title');

          const popup = new PaystackPop();
          popup.newTransaction({
            // Note: replace with actual public key
            key: 'pk_test_placeholder',
            email: 'customer@example.com', // Would normally collect this via a form
            amount: Number(productPrice),
            currency: 'NGN',
            reference: 'txn_' + Math.floor((Math.random() * 1000000000) + 1),
            metadata: {
              custom_fields: [
                {
                  display_name: "Product ID",
                  variable_name: "product_id",
                  value: productId || ''
                },
                {
                  display_name: "Product Title",
                  variable_name: "product_title",
                  value: productTitle || ''
                }
              ]
            },
            onSuccess: (transaction: any) => {
              alert(`Payment successful! Transaction reference: ${transaction.reference}`);
            },
            onCancel: () => {
              console.log('Payment cancelled');
            }
          });
        });
      });
    });
  </script>
</Layout>
