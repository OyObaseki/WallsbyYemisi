        <a href="https://instagram.com/wallsbyyemisi" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 text-[#2D2A26] hover:text-[#C59F58] transition">
          <div class="w-12 h-12 rounded-full bg-[#F3EFE6] flex items-center justify-center text-[#D4AF37]">
