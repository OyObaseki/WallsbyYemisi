---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout>
  <!-- Header -->
  <Header />

  <main class="container mx-auto px-4 py-16 min-h-[60vh] flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-[#2D2A26] mb-4 uppercase tracking-wider">Contact Us</h1>
      <p class="text-[#A39E93] text-lg max-w-2xl mx-auto">Get in touch with us for any inquiries, support, or special requests.</p>
    </div>
  </main>
</Layout>
