---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

const paystackPublicKey = import.meta.env.PAYSTACK_PUBLIC_KEY;
---

<Layout>
  <!-- Header -->
  <Header />

  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">

  <main class="container mx-auto px-4 py-16 min-h-[60vh] max-w-3xl">
    <div id="paystack-pk" data-key={paystackPublicKey} hidden></div>
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-[#2D2A26] mb-4 uppercase tracking-wider">Schedule Inspection</h1>
      <p class="text-[#A39E93] text-lg max-w-2xl mx-auto">Book a time for our experts to assess your space and recommend the perfect mural installations.</p>
    </div>

    <div class="bg-white p-8 md:p-10 rounded-lg shadow-sm border border-gray-100 relative overflow-hidden">
      <form id="inspection-form" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-gray-200 rounded-md focus:ring-2 focus:ring-[#8C7A6B] focus:border-transparent outline-none transition-all bg-gray-50 focus:bg-white" placeholder="Your full name">
          </div>

          <div class="space-y-2">
            <label for="phone" class="block text-sm font-medium text-gray-700">Phone Number</label>
            <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 border border-gray-200 rounded-md focus:ring-2 focus:ring-[#8C7A6B] focus:border-transparent outline-none transition-all bg-gray-50 focus:bg-white" placeholder="Your phone number">
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-gray-200 rounded-md focus:ring-2 focus:ring-[#8C7A6B] focus:border-transparent outline-none transition-all bg-gray-50 focus:bg-white" placeholder="Your email address">
          </div>

          <div class="space-y-2">
            <label for="date" class="block text-sm font-medium text-gray-700">Preferred Date</label>
            <input type="text" id="date" name="date" required readonly class="w-full px-4 py-3 border border-gray-200 rounded-md focus:ring-2 focus:ring-[#8C7A6B] focus:border-transparent outline-none transition-all bg-gray-50 focus:bg-white text-gray-700 cursor-pointer" placeholder="Click to select date on Calendly">
            <p id="calendly-fallback" class="hidden text-sm text-red-500 mt-1">Unable to load calendar. Please refresh or try again later.</p>
            <p id="calendly-success" class="hidden text-sm text-green-600 mt-1 font-medium">Your preferred inspection date has been selected.</p>
          </div>
        </div>

        <div class="space-y-2">
          <label for="state" class="block text-sm font-medium text-gray-700">State</label>
          <select id="state" name="state" required class="w-full px-4 py-3 border border-gray-200 rounded-md focus:ring-2 focus:ring-[#8C7A6B] focus:border-transparent outline-none transition-all bg-gray-50 focus:bg-white text-gray-700 appearance-none">
            <option value="" disabled selected>Select State</option>
            <option value="Abia">Abia</option>
            <option value="Adamawa">Adamawa</option>
            <option value="Akwa Ibom">Akwa Ibom</option>
            <option value="Anambra">Anambra</option>
            <option value="Bauchi">Bauchi</option>
            <option value="Bayelsa">Bayelsa</option>
            <option value="Benue">Benue</option>
            <option value="Borno">Borno</option>
            <option value="Cross River">Cross River</option>
            <option value="Delta">Delta</option>
            <option value="Ebonyi">Ebonyi</option>
            <option value="Edo">Edo</option>
            <option value="Ekiti">Ekiti</option>
            <option value="Enugu">Enugu</option>
            <option value="Federal Capital Territory (FCT)">Federal Capital Territory (FCT)</option>
            <option value="Gombe">Gombe</option>
            <option value="Imo">Imo</option>
            <option value="Jigawa">Jigawa</option>
            <option value="Kaduna">Kaduna</option>
            <option value="Kano">Kano</option>
            <option value="Katsina">Katsina</option>
            <option value="Kebbi">Kebbi</option>
            <option value="Kogi">Kogi</option>
            <option value="Kwara">Kwara</option>
            <option value="Lagos">Lagos</option>
            <option value="Nasarawa">Nasarawa</option>
            <option value="Niger">Niger</option>
            <option value="Ogun">Ogun</option>
            <option value="Ondo">Ondo</option>
            <option value="Osun">Osun</option>
            <option value="Oyo">Oyo</option>
            <option value="Plateau">Plateau</option>
            <option value="Rivers">Rivers</option>
            <option value="Sokoto">Sokoto</option>
            <option value="Taraba">Taraba</option>
            <option value="Yobe">Yobe</option>
            <option value="Zamfara">Zamfara</option>
          </select>
        </div>

        <div class="space-y-2">
          <label for="address" class="block text-sm font-medium text-gray-700">Address</label>
          <input type="text" id="address" name="address" required class="w-full px-4 py-3 border border-gray-200 rounded-md focus:ring-2 focus:ring-[#8C7A6B] focus:border-transparent outline-none transition-all bg-gray-50 focus:bg-white" placeholder="Your full address">
        </div>

        <div class="space-y-2">
          <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 border border-gray-200 rounded-md focus:ring-2 focus:ring-[#8C7A6B] focus:border-transparent outline-none transition-all bg-gray-50 focus:bg-white resize-none" placeholder="Tell us more about your space and what you're looking for..."></textarea>
          <p class="text-sm text-gray-500 mt-2">Note; Inspection fee is 50,000 Naira</p>
        </div>

        <button type="submit" id="submit-btn" disabled class="w-full bg-[#C59F58] hover:bg-[#B08D4C] text-white font-medium py-4 px-6 rounded-full transition-all duration-300 uppercase tracking-wider text-sm mt-8 disabled:opacity-50 disabled:cursor-not-allowed">
          Schedule Now
        </button>

        <div id="payment-error" class="hidden mt-4 text-red-500 text-center font-medium"></div>
      </form>
    </div>
  </main>

  <script is:inline src="https://js.paystack.co/v1/inline.js"></script>
  <script is:inline src="https://assets.calendly.com/assets/external/widget.js"></script>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('inspection-form');
    const submitBtn = document.getElementById('submit-btn');
    const paymentError = document.getElementById('payment-error');
    const dateInput = document.getElementById('date');
    const calendlyFallback = document.getElementById('calendly-fallback');
    const calendlySuccess = document.getElementById('calendly-success');

    // Using vanilla JS logic without TS annotations
    if (form && submitBtn && paymentError && dateInput) {
      // Calendly Integration
      const openCalendly = () => {
        calendlyFallback.classList.add('hidden');
        calendlySuccess.classList.add('hidden');

        // Check if Calendly is loaded
        if (!window.Calendly) {
          calendlyFallback.classList.remove('hidden');
          return;
        }

        const nameInput = document.getElementById('name');
        const emailInput = document.getElementById('email');

        const prefill = {};
        if (nameInput && nameInput.value) prefill.name = nameInput.value;
        if (emailInput && emailInput.value) prefill.email = emailInput.value;

        window.Calendly.initPopupWidget({
          url: 'https://calendly.com/wallsbyyemisi', // Use placeholder/default Calendly link
          prefill: prefill
        });
      };

      dateInput.addEventListener('click', openCalendly);

      // Listen for Calendly events
      const handleCalendlyEvent = (e) => {
        if (e.data && e.data.event === 'calendly.event_scheduled') {
          dateInput.value = "Date Selected via Calendly";
          calendlySuccess.classList.remove('hidden');

          // Trigger form validation update
          const event = new Event('input', { bubbles: true });
          form.dispatchEvent(event);
        }
      };

      window.addEventListener('message', handleCalendlyEvent);

      // Cleanup listener on page transition to prevent duplicate listeners
      document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('message', handleCalendlyEvent);
      }, { once: true });

      // Validate form on input to enable/disable button
      form.addEventListener('input', () => {
        if (form.checkValidity()) {
          submitBtn.disabled = false;
        } else {
          submitBtn.disabled = true;
        }
      });

      // Initial check in case form is pre-filled
      if (form.checkValidity()) {
        submitBtn.disabled = false;
      }

      form.addEventListener('submit', (e) => {
        e.preventDefault();

        // Hide previous errors
        paymentError.classList.add('hidden');

        // Disable button and show processing
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Processing...';
        submitBtn.disabled = true;

        // Extract form data
        const formData = new FormData(form);
        const name = formData.get('name');
        const phone = formData.get('phone');
        const email = formData.get('email');

        // Read Paystack public key
        const pkElement = document.getElementById('paystack-pk');
        const pk = pkElement ? pkElement.getAttribute('data-key') : null;

        if (!pk) {
          console.error("Paystack Public Key not found");
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
          return;
        }

        // Initialize Paystack using @ts-ignore equivalent if compiler complained,
        // but since we aren't using TS types here, PaystackPop comes from the inline script globally.
        // @ts-ignore
        const handler = PaystackPop.setup({
          key: pk,
          email: email,
          amount: 50000 * 100, // 50,000 NGN in kobo
          currency: 'NGN',
          ref: 'INSP_' + Math.floor((Math.random() * 1000000000) + 1),
          metadata: {
            custom_fields: [
              { display_name: "Service Type", variable_name: "service_type", value: "Schedule Inspection" },
              { display_name: "Amount", variable_name: "amount", value: "50000" },
              { display_name: "Order Type", variable_name: "order_type", value: "Inspection Booking" },
              { display_name: "Full Name", variable_name: "name", value: name },
              { display_name: "Phone Number", variable_name: "phone", value: phone }
            ]
          },
          callback: function(response) {
            // Redirect to booking confirmation
            window.location.href = '/booking-confirmation';
          },
          onClose: function() {
            // Re-enable form button and show error
            paymentError.textContent = "Payment not completed. Please try again.";
            paymentError.classList.remove('hidden');
            submitBtn.textContent = 'SCHEDULE NOW';
            submitBtn.disabled = false;
          }
        });

        handler.openIframe();
      });
    }

    // Removing the old logic referencing successMessage/resetBtn because
    // we now redirect instead of showing inline success message.
  });
</script>
