---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { sanityClient } from '../../lib/sanity';

export async function getStaticPaths() {
  let products: any[] = [];
  try {
    products = await sanityClient.fetch(`*[_type == "product"]{
      _id,
      title,
      "description": pt::text(description),
      "imageUrl": featuredImage.asset->url,
      variants
    }`);
  } catch (error) {
    console.error("Error fetching products from Sanity:", error);
  }

  // Fallback mock data if CMS is empty or errors
  if (!products || products.length === 0) {
    products = [
      {
        _id: "mock-1",
        title: "Queen of Orisun",
        description: "Original Canvas",
        imageUrl: "https://images.unsplash.com/photo-1579762715118-a6f1d4b934f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
      },
      {
        _id: "mock-2",
        title: "Night Bloom",
        description: "Art Print",
        imageUrl: "https://images.unsplash.com/photo-1507608158173-1dcec673a2e5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
      },
      {
        _id: "mock-3",
        title: "Golden Hour",
        description: "Mixed Media",
        imageUrl: "https://images.unsplash.com/photo-1550684376-efcbd6e3f031?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
      },
      {
        _id: "mock-4",
        title: "Azure Deep",
        description: "Original Canvas",
        imageUrl: "https://images.unsplash.com/photo-1541961017774-22349e4a1262?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        variants: [
          { title: "20x30 Frameless", price: 75000 },
          { title: "20x30 Framed", price: 83000 },
          { title: "24x36 Frameless", price: 85000 },
          { title: "24x36 Framed", price: 95000 },
          { title: "27x42 Frameless", price: 95000 },
          { title: "27x42 Framed", price: 110000 },
          { title: "36x48 Frameless", price: 105000 },
          { title: "36x48 Framed", price: 120000 }
        ]
      }
    ];
  }

  return products.map((product) => ({
    params: { id: product._id },
    props: { product },
  }));
}

const { product } = Astro.props;
const paystackPublicKey = import.meta.env.PAYSTACK_PUBLIC_KEY;

// Default price logic
let pricing: Record<string, Record<string, number>> = {
  "20x30": { frameless: 75000, framed: 83000 },
  "24x36": { frameless: 85000, framed: 95000 },
  "27x42": { frameless: 95000, framed: 110000 },
  "36x48": { frameless: 105000, framed: 120000 },
};

// Dynamic pricing from variants
if (product.variants && Array.isArray(product.variants)) {
  const dynamicPricing: Record<string, Record<string, number>> = {};

  product.variants.forEach((v: any) => {
    if (v.title && v.price) {
      const parts = v.title.toLowerCase().split(' ');
      if (parts.length >= 2) {
        const size = parts[0]; // e.g., "20x30"
        const frame = parts[1]; // e.g., "frameless" or "framed"

        if (!dynamicPricing[size]) {
          dynamicPricing[size] = {};
        }
        dynamicPricing[size][frame] = v.price;
      }
    }
  });

  // Only override if we successfully parsed some variants
  if (Object.keys(dynamicPricing).length > 0) {
    pricing = dynamicPricing;
  }
}

---

<Layout>
  <!-- Header -->
  <Header />

  <main class="container mx-auto px-4 py-8 max-w-lg md:max-w-4xl">
    <div class="flex flex-col md:flex-row gap-8 items-start">
      <div class="w-full md:w-1/2">
        <div class="relative w-full rounded-[32px] overflow-hidden shadow-sm bg-[#F5F2EA]">
          <img src={product.imageUrl} alt={product.title} class="w-full h-auto object-cover mix-blend-multiply" />
        </div>
      </div>

      <div class="w-full md:w-1/2 flex flex-col">
        <h1 class="text-3xl font-bold text-[#2D2A26] mb-2">{product.title}</h1>
        <p class="text-[#A39E93] text-lg mb-6">{product.description || 'Artwork'}</p>

        <div class="mb-6">
          <h3 class="font-semibold text-[#2D2A26] mb-3">Size</h3>
          <div class="flex flex-wrap gap-3" id="size-options">
            <button class="px-4 py-2 border-2 border-[#D4AF37] bg-[#F5F2EA] text-[#2D2A26] rounded-full font-medium transition size-btn active" data-size="20x30">20x30</button>
            <button class="px-4 py-2 border-2 border-[#EBE6DC] text-[#A39E93] hover:border-[#D4AF37] rounded-full font-medium transition size-btn" data-size="24x36">24x36</button>
            <button class="px-4 py-2 border-2 border-[#EBE6DC] text-[#A39E93] hover:border-[#D4AF37] rounded-full font-medium transition size-btn" data-size="27x42">27x42</button>
            <button class="px-4 py-2 border-2 border-[#EBE6DC] text-[#A39E93] hover:border-[#D4AF37] rounded-full font-medium transition size-btn" data-size="36x48">36x48</button>
          </div>
        </div>

        <div class="mb-8">
          <h3 class="font-semibold text-[#2D2A26] mb-3">Frame</h3>
          <div class="flex flex-wrap gap-3" id="frame-options">
            <button class="px-6 py-2 border-2 border-[#D4AF37] bg-[#F5F2EA] text-[#2D2A26] rounded-full font-medium transition frame-btn active" data-frame="frameless">Frameless</button>
            <button class="px-6 py-2 border-2 border-[#EBE6DC] text-[#A39E93] hover:border-[#D4AF37] rounded-full font-medium transition frame-btn" data-frame="framed">Framed</button>
          </div>
        </div>

        <div class="mt-auto border-t border-[#EBE6DC] pt-6 flex flex-col gap-6">
          <div>
            <p class="text-[#A39E93] text-sm mb-1" id="measurement-display">20x30 Inches</p>
            <span class="text-[#C59F58] font-bold text-3xl" id="price-display">₦75,000</span>
          </div>
          <div id="pricing-data" data-pricing={JSON.stringify(pricing)} hidden></div>
          <div class="flex flex-row gap-4 w-full">
            <button
              id="add-to-cart-btn"
              class="flex-1 flex items-center justify-center border-2 border-[#C59F58] text-[#C59F58] hover:bg-[#F5F2EA] px-8 py-3 rounded-full font-medium transition duration-300"
              data-product-id={product._id}
              data-product-title={product.title}
              data-product-image={product.imageUrl}
            >
              Add to Cart
            </button>
            <button
              id="buy-now-btn"
              class="flex-1 flex items-center justify-center bg-[#C59F58] hover:bg-[#B08D4C] text-white px-8 py-3 rounded-full font-medium transition duration-300"
              data-product-id={product._id}
              data-product-title={product.title}
              data-product-image={product.imageUrl}
            >
              Buy Now
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      let currentSize = "20x30";
      let currentFrame = "frameless";

      const pricingDataEl = document.getElementById('pricing-data');
      let pricing = {};
      if (pricingDataEl && pricingDataEl.getAttribute('data-pricing')) {
        try {
          pricing = JSON.parse(pricingDataEl.getAttribute('data-pricing') || '{}');
        } catch(e) {
          console.error("Error parsing pricing data", e);
        }
      }

      const sizeBtns = document.querySelectorAll('.size-btn');
      const frameBtns = document.querySelectorAll('.frame-btn');
      const priceDisplay = document.getElementById('price-display');
      const measurementDisplay = document.getElementById('measurement-display');
      const buyBtn = document.getElementById('buy-now-btn');
      const addToCartBtn = document.getElementById('add-to-cart-btn');

      function updatePrice() {
        const price = pricing[currentSize][currentFrame];
        if (priceDisplay) {
          priceDisplay.textContent = '₦' + price.toLocaleString();
        }
        if (measurementDisplay) {
          measurementDisplay.textContent = currentSize + ' Inches';
        }
      }

      sizeBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          sizeBtns.forEach(b => {
            b.classList.remove('border-[#D4AF37]', 'bg-[#F5F2EA]', 'text-[#2D2A26]');
            b.classList.add('border-[#EBE6DC]', 'text-[#A39E93]');
          });
          const target = e.currentTarget as HTMLButtonElement;
          target.classList.remove('border-[#EBE6DC]', 'text-[#A39E93]');
          target.classList.add('border-[#D4AF37]', 'bg-[#F5F2EA]', 'text-[#2D2A26]');
          currentSize = target.getAttribute('data-size') || "20x30";
          updatePrice();
        });
      });

      frameBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          frameBtns.forEach(b => {
            b.classList.remove('border-[#D4AF37]', 'bg-[#F5F2EA]', 'text-[#2D2A26]');
            b.classList.add('border-[#EBE6DC]', 'text-[#A39E93]');
          });
          const target = e.currentTarget as HTMLButtonElement;
          target.classList.remove('border-[#EBE6DC]', 'text-[#A39E93]');
          target.classList.add('border-[#D4AF37]', 'bg-[#F5F2EA]', 'text-[#2D2A26]');
          currentFrame = target.getAttribute('data-frame') || "frameless";
          updatePrice();
        });
      });

      if (addToCartBtn) {
        addToCartBtn.addEventListener('click', (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          const productId = btn.getAttribute('data-product-id');
          const productTitle = btn.getAttribute('data-product-title');
          const productImage = btn.getAttribute('data-product-image');
          const price = pricing[currentSize][currentFrame];

          const item = {
            id: productId,
            title: productTitle,
            image: productImage,
            size: currentSize,
            frame: currentFrame,
            price: price,
            quantity: 1
          };

          let cart = [];
          try {
            const savedCart = localStorage.getItem('cart');
            if (savedCart) {
              cart = JSON.parse(savedCart);
            }
          } catch (error) {
            console.error('Error parsing cart from localStorage', error);
          }

          const existingItemIndex = cart.findIndex((i: any) => i.id === item.id && i.size === item.size && i.frame === item.frame);
          if (existingItemIndex > -1) {
            cart[existingItemIndex].quantity += 1;
          } else {
            cart.push(item);
          }

          localStorage.setItem('cart', JSON.stringify(cart));
          document.dispatchEvent(new CustomEvent('cart-updated'));
        });
      }

      if (buyBtn) {
        buyBtn.addEventListener('click', (e) => {
          const btn = e.currentTarget as HTMLButtonElement;
          const productId = btn.getAttribute('data-product-id');
          const productTitle = btn.getAttribute('data-product-title');
          const productImage = btn.getAttribute('data-product-image');
          const price = pricing[currentSize][currentFrame];

          const item = {
            id: productId,
            title: productTitle,
            image: productImage,
            size: currentSize,
            frame: currentFrame,
            price: price,
            quantity: 1
          };

          let cart = [];
          try {
            const savedCart = localStorage.getItem('cart');
            if (savedCart) {
              cart = JSON.parse(savedCart);
            }
          } catch (error) {
            console.error('Error parsing cart from localStorage', error);
          }

          const existingItemIndex = cart.findIndex((i: any) => i.id === item.id && i.size === item.size && i.frame === item.frame);
          if (existingItemIndex > -1) {
            cart[existingItemIndex].quantity += 1;
          } else {
            cart.push(item);
          }

          localStorage.setItem('cart', JSON.stringify(cart));
          document.dispatchEvent(new CustomEvent('cart-updated'));

          window.location.href = '/cart';
        });
      }
    });
  </script>
</Layout>
