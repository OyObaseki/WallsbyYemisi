---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';

// We pass this securely from environment variables
const paystackPublicKey = import.meta.env.PAYSTACK_PUBLIC_KEY;
---

<Layout>
  <!-- Header -->
  <Header />

  <main class="container mx-auto px-4 py-12 max-w-lg md:max-w-2xl min-h-[60vh]">
    <div id="paystack-pk" data-key={paystackPublicKey} hidden></div>
    <div class="text-center mb-10">
      <h1 class="text-4xl font-bold text-[#C59F58] mb-2 uppercase tracking-wide">Payment</h1>
      <p class="text-[#A39E93] text-lg font-medium">Complete your order details below</p>
    </div>

    <!-- Toggle Delivery / Pick Up -->
    <div class="flex justify-center mb-10">
      <div class="bg-[#F5F2EA] p-1 rounded-full flex relative w-full max-w-[300px]">
        <div class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-[#C59F58] rounded-full" transition:name="payment-toggle-highlight"></div>
        <span class="flex-1 text-white relative z-10 py-3 rounded-full font-medium text-center">Delivery</span>
        <a href="/payment-pickup" class="flex-1 text-[#A39E93] hover:text-[#2D2A26] relative z-10 py-3 rounded-full font-medium text-center transition-colors duration-300 block">Pick Up</a>
      </div>
    </div>

    <form id="checkout-form" class="space-y-10">
      <!-- Customer Information Section -->
      <section>
        <h2 class="text-xl font-bold text-[#2D2A26] mb-6">Customer Information</h2>
        <div class="space-y-4">
          <div>
            <label class="sr-only" for="fullName">Full Name</label>
            <input type="text" id="fullName" name="fullName" placeholder="Enter full name" required
                   class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition" />
          </div>
          <div>
            <label class="sr-only" for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter email address" required
                   class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition" />
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="sr-only" for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="Enter phone number" required
                     class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition" />
            </div>
            <div>
              <label class="sr-only" for="altPhone">Alternate Phone Number</label>
              <input type="tel" id="altPhone" name="altPhone" placeholder="Enter alternate phone number"
                     class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition" />
            </div>
          </div>
        </div>
      </section>

      <!-- Delivery Address Section -->
      <section id="delivery-section">
        <h2 class="text-xl font-bold text-[#2D2A26] mb-6">Delivery Address</h2>
        <div class="space-y-4">
          <div>
            <label class="sr-only" for="address">Street Address</label>
            <input type="text" id="address" name="address" placeholder="Street address and apartment/suite number" required
                   class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition" />
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="sr-only" for="city">City / Town</label>
              <input type="text" id="city" name="city" placeholder="Enter city or town" required
                     class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition" />
            </div>
            <div>
              <label class="sr-only" for="state">State</label>
              <select id="state" name="state" required
                      class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl text-[#2D2A26] focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition appearance-none">
                <option value="" disabled selected>Select State</option>
                <option value="Abia">Abia</option>
                <option value="Adamawa">Adamawa</option>
                <option value="Akwa Ibom">Akwa Ibom</option>
                <option value="Anambra">Anambra</option>
                <option value="Bauchi">Bauchi</option>
                <option value="Bayelsa">Bayelsa</option>
                <option value="Benue">Benue</option>
                <option value="Borno">Borno</option>
                <option value="Cross River">Cross River</option>
                <option value="Delta">Delta</option>
                <option value="Ebonyi">Ebonyi</option>
                <option value="Edo">Edo</option>
                <option value="Ekiti">Ekiti</option>
                <option value="Enugu">Enugu</option>
                <option value="Federal Capital Territory (FCT)">Federal Capital Territory (FCT)</option>
                <option value="Gombe">Gombe</option>
                <option value="Imo">Imo</option>
                <option value="Jigawa">Jigawa</option>
                <option value="Kaduna">Kaduna</option>
                <option value="Kano">Kano</option>
                <option value="Katsina">Katsina</option>
                <option value="Kebbi">Kebbi</option>
                <option value="Kogi">Kogi</option>
                <option value="Kwara">Kwara</option>
                <option value="Lagos">Lagos</option>
                <option value="Nasarawa">Nasarawa</option>
                <option value="Niger">Niger</option>
                <option value="Ogun">Ogun</option>
                <option value="Ondo">Ondo</option>
                <option value="Osun">Osun</option>
                <option value="Oyo">Oyo</option>
                <option value="Plateau">Plateau</option>
                <option value="Rivers">Rivers</option>
                <option value="Sokoto">Sokoto</option>
                <option value="Taraba">Taraba</option>
                <option value="Yobe">Yobe</option>
                <option value="Zamfara">Zamfara</option>
              </select>
            </div>
          </div>
          <div>
            <label class="sr-only" for="landmark">Landmark</label>
            <input type="text" id="landmark" name="landmark" placeholder="Nearby landmark (e.g. opposite XYZ Mall)"
                   class="w-full px-5 py-4 bg-[#FDFBF7] border border-[#EBE6DC] rounded-xl focus:outline-none focus:border-[#C59F58] focus:ring-1 focus:ring-[#C59F58] transition" />
          </div>
        </div>

        <div id="delivery-note" class="mt-6 bg-[#F5F2EA] border border-[#EBE6DC] rounded-xl p-4 flex items-start gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#A39E93] mt-0.5 flex-shrink-0">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" x2="12" y1="8" y2="12"></line>
            <line x1="12" x2="12.01" y1="16" y2="16"></line>
          </svg>
          <p class="text-[#A39E93] text-sm leading-relaxed">Note: Delivery agent will reach out to discuss the delivery price.</p>
        </div>
      </section>

      <!-- Order Summary Section -->
      <section>
        <h2 class="text-xl font-bold text-[#2D2A26] mb-6">Order Summary</h2>
        <div class="bg-[#FDFBF7] border border-[#F3EFE6] shadow-sm rounded-3xl p-6">
          <div id="order-items" class="space-y-4 mb-6">
            <!-- Order items will be populated by JS -->
          </div>
          <div class="border-t border-[#EBE6DC] pt-6 flex justify-between items-end">
             <span class="text-lg font-medium text-[#2D2A26]">Estimated Total:</span>
             <span class="text-[#2D2A26] font-bold text-2xl" id="order-total">₦0</span>
          </div>
        </div>
      </section>

      <!-- Pay Now Button -->
      <button type="submit" id="pay-now-btn" class="w-full bg-[#C59F58] hover:bg-[#B08D4C] text-white py-4 rounded-full font-bold text-lg transition duration-300 transform active:scale-[0.98]">
        Pay Now
      </button>

      <div id="payment-error" class="hidden mt-4 text-red-500 text-center font-medium"></div>

    </form>
  </main>
</Layout>

<script is:inline src="https://js.paystack.co/v1/inline.js"></script>

<script>
  function renderPaymentCart() {
    let orderType = 'Delivery';
    // 2. Cart Summary Logic
    const orderItemsContainer = document.getElementById('order-items');
    const orderTotalEl = document.getElementById('order-total');

    if (!orderItemsContainer || !orderTotalEl) return;

    let cart: any[] = [];
    let cartTotal = 0;

    try {
      const savedCart = localStorage.getItem('cart');
      if (savedCart) {
        cart = JSON.parse(savedCart);
      }
    } catch (e) {
      console.error('Error parsing cart', e);
    }

    // Clear container before rendering (useful for view transitions)
    orderItemsContainer.innerHTML = '';

    if (cart.length === 0) {
      orderItemsContainer.innerHTML = '<p class="text-[#A39E93]">Your cart is empty.</p>';
    } else {
        cart.forEach((item) => {
          const itemTotal = item.price * item.quantity;
          cartTotal += itemTotal;

          const el = document.createElement('div');
          el.className = "flex items-center gap-4 py-2";

          const imgEl = document.createElement('img');
          imgEl.src = item.image || '';
          imgEl.alt = item.title;
          imgEl.className = "w-16 h-16 object-cover rounded-lg bg-[#F5F2EA] flex-shrink-0";

          const detailsDiv = document.createElement('div');
          detailsDiv.className = "flex-1 flex justify-between items-center gap-2";

          const infoSpan = document.createElement('span');
          infoSpan.className = "text-[#2D2A26] font-medium text-sm md:text-base break-words";
          infoSpan.textContent = `${item.title} – Qty: ${item.quantity}`;

          const priceSpan = document.createElement('span');
          priceSpan.className = "font-medium text-[#2D2A26] flex-shrink-0";
          priceSpan.textContent = `₦${itemTotal.toLocaleString()}`;

          detailsDiv.appendChild(infoSpan);
          detailsDiv.appendChild(priceSpan);

          el.appendChild(imgEl);
          el.appendChild(detailsDiv);

          orderItemsContainer.appendChild(el);
        });
        orderTotalEl.textContent = '₦' + cartTotal.toLocaleString();
    }

    // 3. Form Submission & Paystack
    const checkoutForm = document.getElementById('checkout-form') as HTMLFormElement;
    const paymentError = document.getElementById('payment-error');

    // Using a meta tag or dataset to pass the public key from Astro safely.
    // However, we imported it in the frontmatter, but to access in script we need to inject it.
    // Instead of directly injecting to script, we can read it if we set it in data attribute on body or main.
    // Or just fetch it. Since it's Astro, we can define a data attribute.

    if (checkoutForm) {
      checkoutForm.addEventListener('submit', (e) => {
        e.preventDefault();

        if (cartTotal <= 0) {
          if (paymentError) {
             paymentError.textContent = "Your cart is empty.";
             paymentError.classList.remove('hidden');
          }
          return;
        }

        const formData = new FormData(checkoutForm);
        const email = formData.get('email') as string;
        const name = formData.get('fullName') as string;
        const phone = formData.get('phone') as string;

        // Disable button
        const btn = document.getElementById('pay-now-btn') as HTMLButtonElement;
        const originalText = btn.textContent;
        btn.textContent = 'Processing...';
        btn.disabled = true;
        if (paymentError) paymentError.classList.add('hidden');

        // We assume PAYSTACK_PUBLIC_KEY is available via a global variable or inline script.
        // Wait, standard way in Astro is to render it in HTML and read it.
        // Let's modify the Astro frontmatter/HTML to include the key.
        const pkElement = document.getElementById('paystack-pk');
        const pk = pkElement ? pkElement.getAttribute('data-key') : null;

        if (!pk) {
           console.error("Paystack Public Key not found");
           btn.textContent = originalText;
           btn.disabled = false;
           return;
        }

        // @ts-ignore
        const handler = PaystackPop.setup({
          key: pk,
          email: email,
          amount: cartTotal * 100, // Paystack expects amount in kobo
          currency: 'NGN',
          ref: 'WBY_' + Math.floor((Math.random() * 1000000000) + 1),
          metadata: {
             custom_fields: [
                { display_name: "Full Name", variable_name: "name", value: name },
                { display_name: "Phone Number", variable_name: "phone", value: phone },
                { display_name: "Order Type", variable_name: "order_type", value: orderType },
                { display_name: "Cart Items", variable_name: "cart_items", value: JSON.stringify(cart) }
             ]
          },
          callback: function(response: any) {
             // Success
             localStorage.removeItem('cart');
             document.dispatchEvent(new CustomEvent('cart-updated'));
             window.location.href = '/payment-success?reference=' + response.reference;
          },
          onClose: function() {
             // Closed without completing
             btn.textContent = originalText;
             btn.disabled = false;
          }
        });

        handler.openIframe();
      });
    }
  }

  // Ensure the script executes on every client-side route
  document.addEventListener("astro:page-load", () => {
    // Small timeout to guarantee DOM elements exist in View Transitions
    setTimeout(renderPaymentCart, 50);
  });

  // Call it immediately for SSR initial load.
  setTimeout(renderPaymentCart, 50);
</script>
