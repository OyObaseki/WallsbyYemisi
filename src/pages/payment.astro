---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- Header -->
  <header class="flex items-center justify-between px-6 py-6 border-b border-[#EBE6DC] bg-[#FCFBF8]">
    <div class="flex items-center gap-4">
      <a href="/" class="text-xl font-bold tracking-tight text-[#2D2A26]">WallsbyYemisi</a>
    </div>

    <div class="flex items-center gap-4">
      <button class="w-10 h-10 rounded-full bg-[#F5F2EA] flex items-center justify-center text-[#333333] hover:bg-[#EAE5D9] transition" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <a href="/cart" class="w-10 h-10 rounded-full bg-[#2D2A26] flex items-center justify-center text-[#F5F2EA] hover:bg-black transition" aria-label="Cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
          <path d="M3 6h18"></path>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </a>
    </div>
  </header>

  <main class="container mx-auto px-4 py-16 max-w-lg md:max-w-xl text-center min-h-[60vh]">
    <div class="w-24 h-24 rounded-full bg-[#F5F2EA] flex items-center justify-center text-[#C59F58] mb-6 mx-auto">
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect width="20" height="14" x="2" y="5" rx="2"></rect>
        <line x1="2" x2="22" y1="10" y2="10"></line>
      </svg>
    </div>

    <h1 class="text-3xl font-bold text-[#2D2A26] mb-4">Payment Page</h1>
    <p class="text-[#A39E93] mb-8">This is a stub payment page. In a full implementation, you would see the Paystack integration or checkout form here.</p>

    <a href="/cart" class="border-2 border-[#C59F58] text-[#C59F58] hover:bg-[#F5F2EA] px-8 py-3 rounded-full font-medium transition duration-300 inline-block">
      Return to Cart
    </a>
  </main>
</Layout>
