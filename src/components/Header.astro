---
const pathname = new URL(Astro.request.url).pathname;

const menuItems = [
  { label: 'Home', href: '/' },
  { label: 'New Arrivals', href: '/new-arrivals' },
  { label: 'Mural Wall Art', href: '/mural-wall-art' },
  { label: 'About Us', href: '/about-us' },
  { label: 'Schedule Inspection', href: '/schedule-inspection' },
  { label: 'Contact Us', href: '/contact-us' },
];

const isActive = (href: string) => {
  if (href === '/') {
    return pathname === '/';
  }
  return pathname.startsWith(href);
};
---

<header class="relative bg-[#FCFBF8] border-b border-[#EBE6DC] z-50">
  <div class="flex items-center justify-between px-6 py-6">
    <!-- Logo -->
    <div class="flex items-center gap-4">
      <a href="/" class="text-xl font-bold tracking-tight text-[#2D2A26]">WallsbyYemisi</a>
    </div>

    <!-- Desktop Menu -->
    <nav class="hidden lg:flex items-center gap-6">
      {menuItems.map((item) => (
        <a
          href={item.href}
          class={`text-sm font-medium transition-colors hover:text-[#D4AF37] ${isActive(item.href) ? 'text-[#D4AF37]' : 'text-[#333333]'}`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Icons & Mobile Menu Button -->
    <div class="flex items-center gap-4">
      <!-- Search -->
      <button class="w-10 h-10 rounded-full bg-[#F5F2EA] flex items-center justify-center text-[#333333] hover:bg-[#EAE5D9] transition" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>

      <!-- Cart -->
      <a href="/cart" class="w-10 h-10 rounded-full bg-[#2D2A26] flex items-center justify-center text-[#F5F2EA] hover:bg-black transition relative" aria-label="Cart">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
          <path d="M3 6h18"></path>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span class="cart-badge absolute -top-1 -right-1 bg-[#D4AF37] text-white text-[10px] font-bold w-5 h-5 rounded-full flex items-center justify-center hidden">0</span>
      </a>

      <!-- Mobile Hamburger -->
      <button id="mobile-menu-btn" class="lg:hidden w-10 h-10 rounded-full bg-[#F5F2EA] flex items-center justify-center text-[#333333] hover:bg-[#EAE5D9] transition" aria-label="Menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 w-full bg-[#FCFBF8] border-b border-[#EBE6DC] shadow-sm">
    <nav class="flex flex-col px-6 py-4 space-y-4">
      {menuItems.map((item) => (
        <a
          href={item.href}
          class={`text-base font-medium transition-colors hover:text-[#D4AF37] ${isActive(item.href) ? 'text-[#D4AF37]' : 'text-[#333333]'}`}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (btn && menu) {
      btn.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  });
</script>