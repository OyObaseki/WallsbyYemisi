{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/about-us/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/send-email/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/send-order/?$",
			"dest": "_render"
		},
		{
			"src": "^/booking-confirmation/?$",
			"dest": "_render"
		},
		{
			"src": "^/cart/?$",
			"dest": "_render"
		},
		{
			"src": "^/catalogue/([^/]+?)/pdf/?$",
			"dest": "_render"
		},
		{
			"src": "^/catalogue/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/collections/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact-us/?$",
			"dest": "_render"
		},
		{
			"src": "^/frame-catalog/?$",
			"dest": "_render"
		},
		{
			"src": "^/mural-catalog/?$",
			"dest": "_render"
		},
		{
			"src": "^/new-arrivals/?$",
			"dest": "_render"
		},
		{
			"src": "^/payment/?$",
			"dest": "_render"
		},
		{
			"src": "^/payment-pickup/?$",
			"dest": "_render"
		},
		{
			"src": "^/payment-success/?$",
			"dest": "_render"
		},
		{
			"src": "^/product/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/schedule-inspection/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}